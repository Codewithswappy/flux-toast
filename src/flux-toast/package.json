{
  "name": "flux-toast",
  "version": "1.0.2",
  "description": "Beautiful, accessible, and performant toast notifications for React. TypeScript-first, SSR-safe, motion-powered.",
  "author": "Codewithswappy",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles": "./dist/styles/index.css",
    "./themes": "./dist/styles/themes.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "react",
    "toast",
    "notification",
    "sonner",
    "react-hot-toast",
    "accessible",
    "typescript",
    "nextjs",
    "ssr",
    "motion",
    "zustand"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Codewithswappy/flux-toast"
  },
  "peerDependencies": {
    "motion": ">=11.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "zustand": ">=4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  }
}
